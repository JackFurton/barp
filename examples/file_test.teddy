// Test file I/O
fn main() {
    // Write to a file
    let content = "Hello from Teddy!\n";
    write_file("test_output.txt\0", content, 18);
    
    // Read it back
    let data = read_file("test_output.txt\0");
    print len(data);
    
    // Free the read buffer (128KB mmap'd by read_file)
    free(data, 131072);
    
    print "Done!";
}
