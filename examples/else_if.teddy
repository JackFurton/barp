// Test: else if chains

fn classify(n) {
    if n > 100 {
        return 3;
    } else if n > 50 {
        return 2;
    } else if n > 0 {
        return 1;
    } else {
        return 0;
    }
}

fn main() {
    print classify(200);
    print classify(75);
    print classify(25);
    print classify(0 - 5);
    return 0;
}
